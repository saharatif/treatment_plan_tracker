DB_PASSWORD=
KMS_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
SMTP_HOST=mailpit          # Mailpit container (docker-compose) — view caught mail at http://localhost:8025
SMTP_PORT=1025             # Mailpit SMTP port; use 587 + SMTP_USE_TLS=true for a real provider
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false         # Mailpit doesn't support STARTTLS; set true for real SMTP providers
SUPABASE_URL=                 # Project Settings -> API -> Project URL
SUPABASE_ANON_KEY=             # Project Settings -> API -> anon/public key
SUPABASE_JWT_SECRET=           # Project Settings -> API -> JWT Settings -> JWT Secret
SUPABASE_SERVICE_ROLE_KEY=     # Project Settings -> API -> service_role key (used by setup_supabase_users.py only)
VITE_SUPABASE_URL=             # same as SUPABASE_URL, baked into the frontend at build time
VITE_SUPABASE_ANON_KEY=        # same as SUPABASE_ANON_KEY, baked into the frontend at build time
AI_OCR_PROVIDER=mistral       # uses Mistral when MISTRAL_API_KEY is set; otherwise local PDF text
AI_PARSER_PROVIDER=openai     # uses OpenAI when OPENAI_API_KEY is set; use "ollama" for local LLM
OLLAMA_BASE_URL=http://localhost:11434
BILLING_EMAIL=
BILLING_PORTAL_BASE_URL=http://localhost:3001
ENABLE_CHECKPOINT_SCHEDULER=false
CHECKPOINT_CRON_HOUR=8
CHECKPOINT_GRACE_ANY_ORB=true
REPORT_OUTPUT_DIR=reports
